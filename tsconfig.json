{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "src",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": ["bun-types"],
    "lib": ["ES2022"],
    "jsx": "preserve",
    "jsxImportSource": "@opentui/solid"
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "test"]
}
